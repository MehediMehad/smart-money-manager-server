generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String         @unique
  password String
  role     UserRoleEnum   @default(USER)
  status   UserStatusEnum @default(DEACTIVATE)

  fcmTokens     String[] // Push 🔔 multiple device support
  isVerified    Boolean   @default(false)
  lastLoginAt   DateTime?
  isSocialLogin Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Financial Relations
  incomes        Income[]
  expenses       Expense[]
  dailyBudgets   DailyBudget[]
  monthlyBudgets MonthlyBudget[]
  savingsGoals   SavingsGoal[]
  debts          Debt[]

  // User-created categories
  categories       Category[]
  hiddenCategories HiddenCategory[]

  // Notification Relations
  notificationsSent     Notification[] @relation("sender")
  notificationsReceived Notification[] @relation("receiver")

  @@map("users")
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      CategoryTypeEnum
  emoji     String
  createdAt DateTime         @default(now())

  // Financial Relations
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  incomes      Income[]
  expenses     Expense[]
  dailyBudgets DailyBudget[]

  hiddenByUsers  HiddenCategory[]
  monthlyBudgets MonthlyBudget[]

  @@unique([name, type, userId])
  @@unique([name, type])
  @@index([type])
  @@map("categories")
}

model HiddenCategory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  categoryId String   @db.ObjectId
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
  @@map("hidden_categories")
}

enum CategoryTypeEnum {
  INCOME
  EXPENSE
}

//////////////////////////////////////////////////////
// INCOME
//////////////////////////////////////////////////////

model Income {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  categoryId String   @db.ObjectId
  amount     Int      @db.Int
  note       String
  date       DateTime

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([categoryId])
  @@index([date])
  @@map("incomes")
}

//////////////////////////////////////////////////////
// EXPENSE
//////////////////////////////////////////////////////

model Expense {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  categoryId String   @db.ObjectId
  amount     Int      @db.Int
  note       String
  date       DateTime

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([categoryId])
  @@index([date])
  @@map("expenses")
}

//////////////////////////////////////////////////////
// DAILY BUDGET
//////////////////////////////////////////////////////

model DailyBudget {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  categoryId String   @db.ObjectId
  amount     Int      @db.Int
  date       DateTime

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, date])
  @@index([userId, date])
  @@index([categoryId])
  @@map("daily_budgets")
}

//////////////////////////////////////////////////////
// MONTHLY BUDGET
//////////////////////////////////////////////////////

model MonthlyBudget {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  categoryId String   @db.ObjectId
  amount     Int      @db.Int
  month      Int
  year       Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month, year])
  @@index([userId, month, year])
  @@index([categoryId])
  @@map("monthly_budgets")
}

//////////////////////////////////////////////////////
// SAVINGS GOAL
//////////////////////////////////////////////////////

model SavingsGoal {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  name         String
  targetAmount Int      @db.Int
  savedAmount  Int      @db.Int
  deadline     DateTime
  createdAt    DateTime @default(now())

  user         User                 @relation(fields: [userId], references: [id])
  transactions SavingsTransaction[]

  @@index([userId])
  @@index([createdAt])
  @@map("savings_goals")
}

//////////////////////////////////////////////////////
// SAVINGS TRANSACTIONS
//////////////////////////////////////////////////////

model SavingsTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  goalId    String   @db.ObjectId
  amount    Int      @db.Int
  createdAt DateTime @default(now())

  goal SavingsGoal @relation(fields: [goalId], references: [id])

  @@index([goalId])
  @@index([createdAt])
  @@index([goalId, createdAt])
  @@map("savings_transactions")
}

//////////////////////////////////////////////////////
// DEBTS
//////////////////////////////////////////////////////

model Debt {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  person    String
  amount    Int        @db.Int
  type      DebtType
  dueDate   DateTime?
  status    DebtStatus @default(PENDING)
  note      String
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([person])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, dueDate])
  @@map("debts")
}

enum DebtType {
  GIVEN
  TAKEN
}

enum DebtStatus {
  PENDING
  PAID
  OVERDUE
}

model Notification {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  // Who sent the notification (null = system)
  senderId String? @db.ObjectId
  sender   User?   @relation("sender", fields: [senderId], references: [id])

  // Who received the notification
  receiverId String @db.ObjectId
  receiver   User   @relation("receiver", fields: [receiverId], references: [id])

  // Content
  title String
  body  String
  data  Json? // Additional data payload

  // 🔥 Generic Type
  type NotificationTypeEnum @default(NOTIFY) // MESSAGE , FRIEND_REQUEST, SYSTEM_ALERT, NOTIFY

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([receiverId, isRead])
  @@index([type])
  @@map("notifications")
}

enum NotificationTypeEnum {
  NOTIFY
  SYSTEM_ALERT
}

model Otp {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  type      OtpTypeEnum //  VERIFY_EMAIL, RESET_PASSWORD, VERIFY_PHONE,
  createdAt DateTime    @default(now())
  expiresAt DateTime

  @@unique([email, code, type])
  @@index([email, type, expiresAt])
  @@map("opts")
}

// Enums
enum OtpTypeEnum {
  LOGIN
  FORGOT_PASSWORD
  VERIFY_EMAIL
  RESET_PASSWORD
  VERIFY_PHONE
  VERIFY_USER
}

enum UserRoleEnum {
  USER
  ADMIN
}

enum UserStatusEnum {
  DEACTIVATE
  ACTIVE
  BLOCKED
}
